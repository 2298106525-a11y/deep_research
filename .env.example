# ============================================
# 多Agent深度研究智能体 - 环境变量配置示例
# ============================================
# 使用说明:
# 1. 复制此文件为 .env
# 2. 将下面的占位符替换为你的实际 API Key
# 3. 不要将 .env 文件提交到版本控制系统

# ============================================
# LLM 配置 (必需)
# ============================================

# OpenAI API Key 或兼容服务的 API Key
# 获取方式:
# - OpenAI: https://platform.openai.com/api-keys
# - 阿里云通义千问: https://dashscope.console.aliyun.com/apiKey
LLM_API_KEY=your_api_key_here

# LLM API 基础 URL
# - OpenAI: https://api.openai.com/v1
# - 阿里云通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# - 其他兼容 OpenAI API 的服务
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# LLM 模型名称
# - OpenAI: gpt-3.5-turbo, gpt-4, gpt-4-turbo
# - 阿里云: qwen-plus, qwen-max, qwen-turbo
# - 其他: 根据服务提供商选择
LLM_MODEL=qwen-plus

# ============================================
# 搜索工具配置 (必需)
# ============================================

# Tavily Search API Key
# 获取方式: https://tavily.com (注册后在 Dashboard 获取)
# 免费额度: 每月 1000 次搜索
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# 研究流程配置 (可选)
# ============================================

# 最大迭代次数 (默认: 3)
# 如果评审不通过，系统会自动重新搜索和分析，最多迭代这么多次
MAX_ITERATIONS=3

# 最低质量分数阈值 (默认: 70)
# 评审分数达到这个值才会通过，范围: 0-100
MIN_QUALITY_SCORE=70

# 每次搜索返回的最大结果数 (默认: 10)
# 增加这个值可以获得更多信息，但会增加 token 使用量
MAX_SEARCH_RESULTS=10

# ============================================
# 输出配置 (可选)
# ============================================

# 研究报告输出目录 (默认: ./output)
OUTPUT_DIR=./output
